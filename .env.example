# Server
PORT=8080

# Google Cloud
GCP_PROJECT_ID=your-gcp-project-id

# Firebase service account key (leave empty to use Application Default Credentials)
FIREBASE_CREDS_PATH=./serviceAccountKey.json

# Game tuning
STARTING_COINS=500
MAX_OFFLINE_SECONDS=28800   # 8 hours

# Set to true to expose /debug/* routes (never in production)
DEBUG_ROUTES=true
